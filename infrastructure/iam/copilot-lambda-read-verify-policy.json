{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListFunctionsForNameDiscovery",
      "Effect": "Allow",
      "Action": ["lambda:ListFunctions"],
      "Resource": "*"
    },
    {
      "Sid": "ReadTownOfWileyLambdaConfigAndFunctionUrl",
