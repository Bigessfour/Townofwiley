{
  "name": "townofwiley-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "ng test",
    "test:unit:browser": "ng test --watch=false --browsers=chromiumHeadless",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:smoke": "playwright test e2e/specs/smoke",
    "test:e2e:install": "playwright install chromium",
    "secrets:init": "node scripts/user-secrets.mjs init",
    "secrets:init:local-passphrase": "node scripts/user-secrets.mjs init --generate-passphrase",
    "secrets:status": "node scripts/user-secrets.mjs status",
    "secrets:unlock": "node scripts/user-secrets.mjs unlock",
    "secrets:lock": "node scripts/user-secrets.mjs lock",
    "secrets:lock:prune": "node scripts/user-secrets.mjs lock --prune-local",
    "secrets:prune-local": "node scripts/user-secrets.mjs prune-local",
    "secrets:import-env": "node scripts/user-secrets.mjs import-env --lock"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.5",
    "@angular/cdk": "^21.2.3",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/material": "^21.2.3",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/source-sans-3": "^5.2.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@vitest/browser-playwright": "^4.1.0",
    "jsdom": "^27.1.0",
    "playwright": "^1.58.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "undici": "^7.24.5"
  }
}
