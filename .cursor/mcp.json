{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["-y", "@angular/cli@21.2.5", "mcp", "--experimental-tool", "modernize"]
    },
    "primeng": {
      "command": "npx",
      "args": ["-y", "@primeng/mcp@21.1.6"]
    },
    "microsoft/playwright-mcp": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "playwright-test": {
      "command": "npx",
      "args": ["playwright", "run-test-mcp-server"]
    }
  }
}
