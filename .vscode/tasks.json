{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "scorer eval town",
      "type": "shell",
      "command": "$env:XAI_API_KEY=[Environment]::GetEnvironmentVariable('XAI_API_KEY','Machine'); web-codegen-scorer eval --env=hello-world/config.mjs --model=grok-4-1-fast --autorater-model=grok-code-fast-1 --skip-ai-summary --limit=1 --prompt-filter=affirmation-app --skip-screenshots --output-directory=web-codegen-scorer-out",
      "isBackground": false,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "scorer eval town retry",
      "type": "shell",
      "command": "$env:XAI_API_KEY=[Environment]::GetEnvironmentVariable('XAI_API_KEY','Machine'); web-codegen-scorer eval --env=hello-world/config.mjs --model=grok-4 --autorater-model=grok-code-fast-1 --skip-ai-summary --limit=1 --prompt-filter=affirmation-app --skip-screenshots --output-directory=web-codegen-scorer-out-2",
      "isBackground": false,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "scorer eval town third",
      "type": "shell",
      "command": "$env:XAI_API_KEY=[Environment]::GetEnvironmentVariable('XAI_API_KEY','Machine'); web-codegen-scorer eval --env=hello-world/config.mjs --model=grok-4 --autorater-model=grok-code-fast-1 --skip-ai-summary --limit=1 --prompt-filter=affirmation-app --skip-screenshots --output-directory=web-codegen-scorer-out-3",
      "isBackground": false,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "scorer eval town fourth",
      "type": "shell",
      "command": "$env:XAI_API_KEY=[Environment]::GetEnvironmentVariable('XAI_API_KEY','Machine'); web-codegen-scorer eval --env=hello-world/config.mjs --model=grok-4 --autorater-model=grok-code-fast-1 --skip-ai-summary --limit=1 --prompt-filter=affirmation-app --skip-screenshots --output-directory=web-codegen-scorer-out-4",
      "isBackground": false,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "scorer eval town fifth",
      "type": "shell",
      "command": "$env:XAI_API_KEY=[Environment]::GetEnvironmentVariable('XAI_API_KEY','Machine'); web-codegen-scorer eval --env=hello-world/config.mjs --model=grok-4 --autorater-model=grok-code-fast-1 --skip-ai-summary --limit=1 --prompt-filter=affirmation-app --skip-screenshots --output-directory=web-codegen-scorer-out-5",
      "isBackground": false,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "rerun-failed-playwright-tests",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@playwright/test/cli.js' test e2e/specs/best-practices/deterministic-coverage.spec.ts e2e/specs/smoke/feature-pages.spec.ts --project=desktop-chromium --grep 'captures the homepage section navigation accessibility tree|captures the site-language accessibility group|keeps the homepage hero visually stable|keeps the weather summary card visually stable|filters external news coverage against a fixed clock|business directory snapshot|meetings calendar tab interaction'",
      "isBackground": false,
      "problemMatcher": ["$playwright"],
      "group": "build"
    },
    {
      "label": "build",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@angular/cli/bin/ng.js' build",
      "group": "build"
    },
    {
      "label": "test:unit",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@angular/cli/bin/ng.js' test",
      "group": "test"
    },
    {
      "label": "test:e2e:smoke",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@playwright/test/cli.js' test e2e/specs/smoke --workers=1",
      "group": "test"
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@angular/cli/bin/ng.js' lint",
      "group": "build"
    },
    {
      "label": "format",
      "type": "shell",
      "command": "trunk fmt",
      "group": "build"
    },
    {
      "label": "serve:debug",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@angular/cli/bin/ng.js' serve --host 127.0.0.1 --port 4300",
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "fileLocation": "absolute",
          "pattern": {
            "regexp": "^(.*)$",
            "message": 1
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".",
            "endsPattern": "Local:\\s+http://127.0.0.1:4300"
          }
        }
      ],
      "group": "build"
    },
    {
      "label": "Update ai chat html",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "$env:PATH='/opt/homebrew/opt/node@24/bin;' + $env:PATH; & '/opt/homebrew/opt/node@24/bin/node' fix_ai_chat.js"
    },
    {
      "label": "validate weather smoke proxy",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@playwright/test/cli.js'",
      "args": [
        "playwright",
        "test",
        "e2e/specs/smoke/home.weather.spec.ts",
        "--project=desktop-chromium",
        "--grep",
        "renders the weather panel from the AWS proxy configuration",
        "--reporter=line"
      ],
      "isBackground": false,
      "group": "test"
    },
    {
      "label": "local frontend smoke desktop serial",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@playwright/test/cli.js'",
      "args": [
        "playwright",
        "test",
        "e2e/specs/smoke",
        "--project=desktop-chromium",
        "--workers=1"
      ],
      "isBackground": false,
      "group": "test"
    },
    {
      "label": "smoke: meetings spec",
      "type": "shell",
      "options": {
        "env": {
          "PATH": "/opt/homebrew/opt/node@24/bin;${env:PATH}"
        }
      },
      "command": "& '/opt/homebrew/opt/node@24/bin/node' 'node_modules/@playwright/test/cli.js' test e2e/specs/smoke/feature-pages.spec.ts --project=desktop-chromium --grep \"meetings page keeps the calendar and meeting summary reachable\" --workers=1",
      "isBackground": false,
      "group": "test"
    }
  ]
}
