{
  "files.exclude": {
    "amplify/.config": true,
    "amplify/**/*-parameters.json": true,
    "amplify/**/amplify.state": true,
    "amplify/**/transform.conf.json": true,
    "amplify/#current-cloud-backend": true,
    "amplify/backend/amplify-meta.json": true,
    "amplify/backend/awscloudformation": true
  },
  "terminal.integrated.hideOnStartup": "never",
  "terminal.integrated.shellIntegration.enabled": false,
  "terminal.integrated.tabs.enabled": true,
  "terminal.integrated.tabs.hideCondition": "never",
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.rulers": [100],
  "editor.renderWhitespace": "selection",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "search.exclude": {
    "**/dist": true,
    "**/coverage": true,
    "**/.angular": true
  },
  "terminal.integrated.env.osx": {
    "PATH": "/opt/homebrew/opt/node@24/bin:${env:PATH}"
  },
  "terminal.integrated.env.windows": {
    "NPM_CONFIG_PREFIX": "${env:APPDATA}\\npm"
  },
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "python.defaultInterpreterPath": "/usr/bin/python3",
  "python.envFile": "${workspaceFolder}/secrets/local/.env",
  "python.languageServer": "Pylance",
  "python.logging.level": "warning",
  "python.terminal.activateEnvironment": false,
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["infrastructure"],
  "python.testing.unittestEnabled": true,
  "python.testing.unittestArgs": ["discover", "infrastructure/site-monitor/tests"],
  "python.testing.autoTestDiscoverOnSaveEnabled": false,
  "[typescript]": {
    "editor.defaultFormatter": "trunk.io",
    "editor.formatOnSave": true
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[scss]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "prettier.requireConfig": true,
  "prettier.packageManager": "npm",
  "prettier.printWidth": 100,
  "prettier.singleQuote": true,
  "prettier.trailingComma": "all",
  "prettier.bracketSameLine": false,
  "prettier.endOfLine": "lf",
  "eslint.useFlatConfig": true,
  "eslint.validate": ["typescript", "html"],
  "eslint.format.enable": true,
  "eslint.packageManager": "npm",
  "eslint.run": "onType",
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "eslint.provideLintTask": true,
  "eslint.codeActionsOnSave.mode": "problems",
  "eslint.problems.shortenToSingleLine": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll.eslint": "explicit"
  },
  "angular.forceStrictTemplates": true,
  "angular.suggest.autoImports": true,
  "angular.suggest.includeCompletionsWithSnippetText": true,
  "angular.suggest.includeAutomaticOptionalChainCompletions": true,
  "angular.server.useClientSideFileWatcher": true,
  "angular.log": "off",
  "angular.trace.server": "off",
  "tailwindCSS.experimental.configFile": "src/styles.scss",
  "tailwindCSS.includeLanguages": {
    "html": "html",
    "angular-html": "html",
    "typescript": "javascript",
    "scss": "css"
  },
  "tailwindCSS.classAttributes": ["class", "className", "ngClass", "classList"],
  "tailwindCSS.validate": true,
  "tailwindCSS.colorDecorators": true,
  "tailwindCSS.showPixelEquivalents": true,
  "tailwindCSS.rootFontSize": 16,
  "tailwindCSS.lint.cssConflict": "warning",
  "tailwindCSS.lint.invalidApply": "error",
  "tailwindCSS.lint.invalidConfigPath": "error",
  "tailwindCSS.lint.invalidScreen": "error",
  "tailwindCSS.lint.invalidVariant": "error",
  "tailwindCSS.lint.recommendedVariantOrder": "warning",
  "tailwindCSS.lint.suggestCanonicalClasses": "warning",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "files.associations": {
    "*.component.html": "html"
  },
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "nxConsole.enableCodeLens": true,
  "nxConsole.enableLibraryImports": true,
  "nxConsole.projectViewingStyle": "tree",
  "nxConsole.refreshOnBranchSwitch": true,
  "nxConsole.showNodeVersionOnStartup": true,
  "errorLens.enabled": true,
  "errorLens.messageEnabled": true,
  "errorLens.messageMaxChars": 180,
  "errorLens.removeLinebreaks": true,
  "errorLens.gutterIconsEnabled": true,
  "errorLens.statusBarIconsEnabled": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning", "info"],
  "coverage-gutters.coverageBaseDir": "${workspaceFolder}",
  "coverage-gutters.coverageFileNames": [
    "coverage/lcov.info",
    "coverage/**/lcov.info",
    "coverage.xml",
    "cobertura.xml"
  ],
  "coverage-gutters.showGutterCoverage": true,
  "coverage-gutters.showLineCoverage": true,
  "coverage-gutters.showRulerCoverage": true,
  "coverage-gutters.watchOnActivate": false,
  "gitlens.codeLens.enabled": true,
  "gitlens.currentLine.enabled": true,
  "gitlens.currentLine.dateFormat": "MMM d, yyyy",
  "gitlens.blame.dateFormat": "MMM d, yyyy",
  "gitlens.advanced.fileHistoryFollowsRenames": true,
  "gitlens.advanced.maxListItems": 500,
  "gitlens.ai.enabled": false,
  "playwright.env": {
    "PATH": "/opt/homebrew/opt/node@24/bin:${env:PATH}"
  },
  "playwright.reuseBrowser": false,
  "playwright.showTrace": true,
  "playwright.updateSnapshots": "missing",
  "playwright.runGlobalSetupOnEachRun": true,
  "playwright.pickLocatorCopyToClipboard": true,
  "github.copilot.chat.useInstructionFiles": true,
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "chat.agent.enabled": true,
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.tools.memory.enabled": true,
  "github.copilot.chat.agent.currentEditorContext.enabled": true,
  "github.copilot.chat.agent.largeToolResultsToDisk.enabled": true,
  "github.copilot.chat.agent.largeToolResultsToDisk.thresholdBytes": 12288,
  "github.copilot.chat.agentDebugLog.enabled": true,
  "chat.useAgentsMdFile": true,
  "github.copilot.chat.agent.thinkingTool": true,
  "github.copilot.chat.agentDebugLog.fileLogging.enabled": true,
  "github.copilot.chat.agentDebugLog.fileLogging.maxRetainedSessionLogs": 12,
  "github.copilot.chat.agentDebugLog.fileLogging.maxSessionLogSizeMB": 25,
  "aws.telemetry": false,
  "aws.profile": "copilot",
  "aws.region": "us-east-2",
  "aws.cloudformation.completion.enabled": true,
  "aws.cloudformation.diagnostics.cfnLint.enabled": true,
  "aws.cloudformation.diagnostics.cfnLint.lintOnChange": true,
  "aws.cloudformation.diagnostics.cfnGuard.enabled": true,
  "aws.samcli.enableCodeLenses": true,
  "aws.suppressPrompts": {
    "lambdaUploadBucket": true
  },
  "mcpAwsCli.defaultRegion": "us-east-2",
  "mcpAwsCli.maxRetries": 3,
  "mcpAwsCli.cacheTimeout": 300,
  "mcpAwsCli.enableDebugLogs": false,
  "amplifyBackend.explorerFilters": ["amplify/backend", "amplify/#current-cloud-backend"],
  "trunk.addToolsToPath": true,
  "trunk.inlineDecorators": true,
  "trunk.inlineDecoratorsForAllExtensions": true,
  "trunk.showPreexistingIssues": true,
  "trunk.showBelowThresholdIssues": false,
  "trunk.numJobs": 4,
  "trunk.trace.server": "off",
  "cSpell.words": ["datatable", "inputnumber", "selectbutton", "togglebutton"],
  "todo-tree.general.tags": ["TODO", "FIXME", "BUG", "HACK", "NOTE"],
  "todo-tree.regex.regex": "(//|#|<!--|;|/\\*|^\\s*\\*)\\s*($TAGS).*",
  "todo-tree.regex.tags": "TODO|FIXME|BUG|HACK|NOTE",
  "todo-tree.highlights.defaultDescription": "Click to toggle visibility of the Todo Tree panel",
  "todo-tree.highlights.customHighlight": {
    "TODO": {
      "icon": "check",
      "foreground": "white",
      "background": "var(--vscode-todoTree-background--todo)"
    },
    "FIXME": {
      "icon": "flame",
      "foreground": "white",
      "background": "var(--vscode-todoTree-background--fixme)"
    },
    "BUG": {
      "icon": "bug",
      "foreground": "white",
      "background": "var(--vscode-todoTree-background--bug)"
    }
  },
  "todo-tree.fileSupport": ["**/*.ts", "**/*.html", "**/*.scss", "**/*.md"]
}
